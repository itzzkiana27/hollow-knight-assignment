--- a/core/src/main/java/com/hollowknight/model/save/DatabaseSaveManager.java	1970-01-01 00:00:00.000000000 +0000
+++ b/core/src/main/java/com/hollowknight/model/save/DatabaseSaveManager.java	2026-07-09 18:25:21.325494509 +0000
@@ -0,0 +1,92 @@
+package com.hollowknight.model.save;
+
+import com.badlogic.gdx.Gdx;
+import com.badlogic.gdx.Preferences;
+import com.badlogic.gdx.utils.Json;
+import com.badlogic.gdx.utils.JsonWriter;
+
+/**
+ * Optional NoSQL-style save backend.
+ *
+ * LibGDX Preferences are used here as a small local key-value database:
+ * the full GameData JSON document is stored under one database key, and a
+ * timestamp is stored under another key. This keeps the project dependency-free
+ * while still demonstrating a database-backed save/load path in addition to
+ * the plain JSON file.
+ */
+public class DatabaseSaveManager {
+    private static final String DATABASE_NAME =
+        "hollow-knight-save-database";
+
+    private static final String GAME_DATA_KEY =
+        "gameDataJson";
+
+    private static final String SAVED_AT_KEY =
+        "savedAtMillis";
+
+    private final Preferences database;
+    private final Json json;
+
+    public DatabaseSaveManager() {
+        database = Gdx.app.getPreferences(
+            DATABASE_NAME
+        );
+
+        json = new Json();
+        json.setUsePrototypes(false);
+        json.setOutputType(
+            JsonWriter.OutputType.json
+        );
+    }
+
+    public void save(GameData data) {
+        if (data == null) {
+            return;
+        }
+
+        database.putString(
+            GAME_DATA_KEY,
+            json.toJson(data)
+        );
+
+        database.putLong(
+            SAVED_AT_KEY,
+            System.currentTimeMillis()
+        );
+
+        database.flush();
+    }
+
+    public GameData load() {
+        String storedJson = database.getString(
+            GAME_DATA_KEY,
+            ""
+        );
+
+        if (storedJson == null || storedJson.isEmpty()) {
+            return null;
+        }
+
+        return json.fromJson(
+            GameData.class,
+            storedJson
+        );
+    }
+
+    public boolean hasSave() {
+        String storedJson = database.getString(
+            GAME_DATA_KEY,
+            ""
+        );
+
+        return storedJson != null
+            && !storedJson.isEmpty();
+    }
+
+    public long getSavedAtMillis() {
+        return database.getLong(
+            SAVED_AT_KEY,
+            0L
+        );
+    }
+}
